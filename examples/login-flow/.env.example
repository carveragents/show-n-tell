# Copy to .env in your working dir (NOT here in the example dir) and fill in
# real values. .env is auto-loaded by record_demo.py from the working dir.
#
# Never commit a real .env file. Only this .env.example (with placeholder
# values and no secrets) is safe to check in.

# Required: TTS provider key for narration synthesis. The Halyard example
# uses OpenAI; swap providers in branding.yaml's `voice:` block if needed.
OPENAI_API_KEY=sk-__REPLACE_ME__

# Login credentials for the target site. The pre_session block in
# demo_config.yaml references these by `${ACME_DEMO_EMAIL}` / `${ACME_DEMO_PASSWORD}`.
# Use a throwaway demo account, never a real human's login.
ACME_DEMO_EMAIL=demo@example.com
ACME_DEMO_PASSWORD=__REPLACE_ME__
